# Anthropic API — Enfoque 7 / 7.1 / 7.2
# Copia este archivo a `.env` (sin el sufijo .example) y rellena los valores.
# Obtén tu clave en: https://console.anthropic.com/

ANTHROPIC_API_KEY=sk-ant-api03-REEMPLAZA-AQUI

# Opcionales — con defaults razonables en config.py
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_TEMPERATURE=0.1
# ANTHROPIC_MAX_TOKENS=1024
# ANTHROPIC_PROMPT_CACHE=true


# NVIDIA NIM API — Enfoque 7.5 / 7.6
# Obtén tu clave en: https://build.nvidia.com/ (botón "Get API Key" en la página del modelo)

NVIDIA_API_KEY=nvapi-REEMPLAZA-AQUI

# Opcionales — con defaults razonables en config.py de 7.5/7.6
# NVIDIA_MODEL=google/gemma-4-31b-it
# NVIDIA_URL=https://integrate.api.nvidia.com/v1/chat/completions
# NVIDIA_TEMPERATURE=1
# NVIDIA_TOP_P=0.95
# NVIDIA_MAX_TOKENS=1024
# NVIDIA_STREAM=true
# NVIDIA_ENABLE_THINKING=false
# NVIDIA_TIMEOUT=600
# NVIDIA_MAX_RETRIES=3


# Ollama local — Enfoque 7.3 / 7.4 (sin API key, solo URL/modelo)
# OLLAMA_MODEL=jobautomation/OpenEuroLLM-Spanish
# OLLAMA_URL=http://localhost:11434/api/chat
# OLLAMA_TEMPERATURE=0.1
# OLLAMA_MAX_TOKENS=1024


# Submission MSLG-SPA 2026 — todos los enfoques
# TEAM_NAME=PrismaticVision
# SOLUTION_NAME=FewShot10RagCurriculum
# SUBMISSION_INCLUDE_ID=false


# COMET (solo MSLG2SPA — enfoques 7.2 / 7.4 / 7.6)
# ENABLE_COMET=true
# COMET_MODEL=Unbabel/wmt22-comet-da
# COMET_BIN=comet-score
# COMET_GPUS=0
# COMET_BATCH_SIZE=8
